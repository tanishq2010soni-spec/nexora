# Calling Agent Environment Variables
# Copy this file to .env and fill in values

# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
CA_SECRET_KEY=

# Database
CA_DATABASE_URL=sqlite+aiosqlite:///./calling_agent.db

# Redis
CA_REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
CA_CORS_ORIGINS=["http://localhost:3000","http://localhost:8200"]

# Server
CA_HOST=0.0.0.0
CA_PORT=8200
CA_DEBUG=false

# Auth Mode: "legacy" (local JWT) or "unified" (Nexora-issued JWT)
CA_AUTH_MODE=legacy

# Control Plane URL (for unified auth)
CA_NEXORA_CONTROL_PLANE_URL=http://localhost:8000
