# WhatsApp Agent Environment Variables
# Copy this file to .env and fill in values

# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
WA_SECRET_KEY=

# Database
WA_DATABASE_URL=sqlite+aiosqlite:///./whatsapp_agent.db

# Redis
WA_REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
WA_CORS_ORIGINS=["http://localhost:3000","http://localhost:8100"]

# Server
WA_HOST=0.0.0.0
WA_PORT=8100
WA_DEBUG=false

# Auth Mode: "legacy" (local JWT) or "unified" (Nexora-issued JWT)
WA_AUTH_MODE=legacy

# Control Plane URL (for unified auth)
WA_NEXORA_CONTROL_PLANE_URL=http://localhost:8000
