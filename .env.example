# ==================================================
# NEXORA ENVIRONMENT CONFIGURATION
# ==================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ==================================================

# Application
ENVIRONMENT=development
APP_NAME=NexoraBrain
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
# Production: set via Docker secrets or environment variable
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexora_db

# Security
# JWT_SECRET_KEY: min 32 characters, REQUIRED in production
# JWT_SECRET_KEY=your_super_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# AI / Vector DB
OLLAMA_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0

# ==================================================
# META (WhatsApp / Facebook / Instagram)
# ==================================================
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=
# META_APP_SECRET=
# META_API_VERSION=v21.0

# ==================================================
# TWILIO (Voice AI)
# ==================================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_WEBHOOK_URL=

# ==================================================
# STRIPE (Payments)
# ==================================================
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ==================================================
# RAZORPAY (Payments - India)
# ==================================================
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ==================================================
# SMTP (Email)
# ==================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@nexora.com

# ==================================================
# SENTRY (Error Tracking)
# ==================================================
# SENTRY_DSN=

# ==================================================
# AGENT REGISTRATION (temporary internal key)
# ==================================================
# Used for agent-to-brain communication (registration, heartbeat)
# REQUIRED in production — generate a secure random value
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_REGISTRATION_KEY=CHANGE_ME_IN_PRODUCTION

# PROVIDER API KEY ENCRYPTION
# ==================================================
# Used to encrypt/decrypt provider API keys at rest
# REQUIRED in production — generate a Fernet key
# Example: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROVIDER_ENCRYPTION_KEY=
