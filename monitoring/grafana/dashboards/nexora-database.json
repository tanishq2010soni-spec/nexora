{
  "title": "Nexora Database",
  "uid": "nexora-database",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["nexora", "database"],
  "timezone": "utc",
  "panels": [
    {
      "title": "PostgreSQL Connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "pg_stat_activity_count", "legendFormat": "Active"},
        {"expr": "pg_stat_activity_max_connections", "legendFormat": "Max"}
      ]
    },
    {
      "title": "PostgreSQL Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
      "targets": [
        {"expr": "rate(pg_stat_database_blks_hit[5m]) / (rate(pg_stat_database_blks_hit[5m]) + rate(pg_stat_database_blks_read[5m])) * 100", "legendFormat": "Hit Ratio %"}
      ]
    },
    {
      "title": "Redis Memory",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "targets": [
        {"expr": "redis_memory_used_bytes", "legendFormat": "Used"},
        {"expr": "redis_memory_max_bytes", "legendFormat": "Max"}
      ]
    },
    {
      "title": "Redis Hit Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "targets": [
        {"expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100", "legendFormat": "Hit Rate %"}
      ]
    }
  ]
}
